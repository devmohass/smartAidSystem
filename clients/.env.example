# SmartAid client configuration.
# Copy to `.env.local` (gitignored) and adjust per environment.

# Base URL the client calls. Leave unset in dev — requests go to "/api" and the
# Vite proxy (vite.config.js) forwards them to the backend on localhost:3000.
# In production, set this to the API origin INCLUDING the /api prefix, e.g.:
#   VITE_API_URL=https://api.smartaid.example/api
# (Not needed if the backend serves the built client from the same origin.)
# VITE_API_URL=

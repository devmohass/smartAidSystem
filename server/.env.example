# SmartAid server configuration. Copy to `.env` (gitignored) and fill in.

# HTTP port the API listens on.
PORT=3000

# --- Database (Postgres) ---
# When running via docker-compose, DB_HOST is the compose service name "db".
# For running the server directly on the host, use "localhost".
DB_USER=smartAid_user
DB_HOST=db
DB_NAME=smartAid_db
DB_PASSWORD=smartAid_123
DB_PORT=5432
# node-pg-migrate reads this. Keep it in sync with the values above.
DATABASE_URL=postgresql://smartAid_user:smartAid_123@db:5432/smartAid_db

# --- Auth ---
# Use a long, random secret in every real environment (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-string

# --- Deployment hardening (optional) ---
# Comma-separated CORS allowlist. Leave empty in dev (any origin allowed).
# Example: CORS_ORIGIN=https://smartaid.example,https://www.smartaid.example
CORS_ORIGIN=
# Absolute path to a built client (clients/dist) to serve the SPA from this
# server. Leave unset to run API-only.
CLIENT_DIST=
